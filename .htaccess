# All-Seeing-Eye — Apache configuration
# Place this file in the same directory as index.html

# ── Whitelist cron-job.org executor IPs (bypass SiteGround bot protection) ────
# These are the official cron-job.org executor node IPs.
# Source: https://api.cron-job.org/executor-nodes.json
# Without this, SiteGround's SGcaptcha intercepts requests before PHP runs.
SetEnvIf Remote_Addr "116\.203\.129\.16"  cron_allowed
SetEnvIf Remote_Addr "116\.203\.134\.67"  cron_allowed
SetEnvIf Remote_Addr "23\.88\.105\.37"    cron_allowed
SetEnvIf Remote_Addr "128\.140\.8\.200"   cron_allowed
SetEnvIf Remote_Addr "91\.99\.23\.109"    cron_allowed

<Files "update-stats.php">
    Order Allow,Deny
    Allow from env=cron_allowed
    Allow from 127.0.0.1
    # Also allow direct browser access for manual runs (remove if you want strict)
    Allow from all
</Files>

<Files "webhook.do">
    Allow from all
</Files>

# ── Prevent browser caching of the app files ─────────────────────
# Forces the browser to always fetch fresh HTML/JS/CSS — prevents
# stale cached versions after an update.
<FilesMatch "\.(html|js|css|php)$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
</FilesMatch>

# ── Route webhook.do to the webhook HTML file ─────────────────────
RewriteEngine On
RewriteRule ^webhook\.do$ webhook.do [L,T=text/html]

# ── Protect sensitive files ───────────────────────────────────────
# Protect sensitive data files from direct browser access.
# These are read/written by PHP scripts internally only.
<FilesMatch "^(ase_config\.json|uptime\.json|notify_secret\.key|notify_rate\.json|cron_notify_sent\.json|domains\.stats|cron\.log)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
